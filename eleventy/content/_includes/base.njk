<!doctype html>
<html lang="en">
<head>
	<meta charset="utf-8">
	<meta name="viewport" content="width=device-width, initial-scale=1">
	<title>{{ title }}</title>
	<style>
		body {
			font-family: system-ui, sans-serif;
			max-width: 48rem;
			margin: 0 auto;
			padding: 1rem;
			line-height: 1.6;
			color: #222;
			background: #fff;
		}
		@media (prefers-color-scheme: dark) {
			body { color: #ddd; background: #1a1a1a; }
			a { color: #6cb4ff; }
		}
		a { color: #0066cc; }
		h1 { margin-top: 0; }
	</style>
</head>
<body>
	{{ content | safe }}
</body>
</html>
